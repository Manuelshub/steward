{
  "name": "@steward/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Typed wrapper over flowvault-sdk exposing Steward's flows in @steward/core types.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node --test --test-reporter spec dist/*.test.js"
  },
  "dependencies": {
    "@steward/core": "*",
    "flowvault-sdk": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3"
  }
}
