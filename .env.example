# ─── Steward environment ─────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env. See ARCHITECTURE.md §8, §10.

# --- Network (contract + token principals MUST be the same network) ---
STACKS_NETWORK=testnet                      # testnet | mainnet

# --- Contract principals (DEPLOYED testnet instances — see docs/deployment.md) ---
# steward-router calls OUR flowvault-v2 instance, so reads/writes target that one.
FLOWVAULT_CONTRACT=ST2PQ72SDAPWV64WH0K5ZH0HK4FPMFMAPV583Z799.flowvault-v2
STEWARD_ROUTER_CONTRACT=ST2PQ72SDAPWV64WH0K5ZH0HK4FPMFMAPV583Z799.steward-router
# Demo token: mock-usdcx (has a public `mint`, guaranteed to work). The official USDCx is
# ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.usdcx (runtime arg; trait-conformance untested).
TOKEN_CONTRACT=ST2PQ72SDAPWV64WH0K5ZH0HK4FPMFMAPV583Z799.mock-usdcx

# --- Agent operator key (SERVER-ONLY — never exposed to the browser) ---
OPERATOR_MNEMONIC=                           # OR OPERATOR_PRIVATE_KEY; used only in apps/agent
OPERATOR_STX_ADDRESS=

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=
STEWARD_REASONING_MODEL=claude-opus-4-8      # deep policy reasoning
STEWARD_ROUTINE_MODEL=claude-haiku-4-5       # cheap routine cycles

# --- Agent behavior ---
AGENT_CYCLE_INTERVAL_MS=60000                # how often the agent re-evaluates
RESERVE_FLOOR=                               # min locked amount (string, base units)

# --- Web (public) ---
NEXT_PUBLIC_STACKS_NETWORK=testnet
NEXT_PUBLIC_FLOWVAULT_CONTRACT=ST2PQ72SDAPWV64WH0K5ZH0HK4FPMFMAPV583Z799.flowvault-v2
NEXT_PUBLIC_STEWARD_ROUTER_CONTRACT=ST2PQ72SDAPWV64WH0K5ZH0HK4FPMFMAPV583Z799.steward-router
NEXT_PUBLIC_TOKEN_CONTRACT=ST2PQ72SDAPWV64WH0K5ZH0HK4FPMFMAPV583Z799.mock-usdcx
